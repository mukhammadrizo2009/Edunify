# Django Settings
SECRET_KEY=your_secret_key_here
DEBUG=False

# Database Configuration (for PostgreSQL on Render/Railway)
DATABASE_URL=postgres://user:password@hostname:port/dbname

# Cloudflare R2 Settings (for Media Storage)
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_ACCESS_KEY_ID=your_access_key
CLOUDFLARE_SECRET_ACCESS_KEY=your_secret_key
CLOUDFLARE_BUCKET_NAME=your_bucket_name
CLOUDFLARE_CUSTOM_DOMAIN=cdn.yourdomain.com

# Cloudinary Settings (Fallback if Cloudflare is not used)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Gemini AI Settings
GEMINI_API_KEY=your_gemini_api_key

# Google OAuth2 Settings
GOOGLE_OAUTH2_KEY=your_google_oauth2_key
GOOGLE_OAUTH2_SECRET=your_google_oauth2_secret
GOOGLE_OAUTH2_REDIRECT_URI=https://www.edunify.online/auth/complete/google-oauth2/
